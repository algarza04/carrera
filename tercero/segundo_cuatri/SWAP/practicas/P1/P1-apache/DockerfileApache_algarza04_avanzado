FROM debian:latest

ENV DEBIAN_FRONTEND=nointeractive

RUN apt update && apt install -y apache2 php libapache2-mod-php php-mysqli && \
    rm -rf /var/lib/apt/lists/*

RUN echo "memory_limit = 512M" > /etc/php/8.2/apache2/php.ini

COPY web_algarza04/test_a1.php /var/www/html/

EXPOSE 80

CMD apache2ctl -D FOREGROUND && tail -f /dev/null
# Crea el contenedor a partir de la última imágen de Nginx
FROM nginx:latest

# Crear directorio para SSL
RUN mkdir -p /etc/nginx/ssl

# Copiar certificados SSL al contenedor
COPY P4-algarza04-certificados/certificado_algarza04.crt /etc/nginx/ssl/certificado_algarza04.crt
COPY P4-algarza04-certificados/certificado_algarza04.key /etc/nginx/ssl/certificado_algarza04.key

# Incluir configuración de Nginx para SSL
COPY P4-algarza04-nginx/algarza04-nginx-ssl.conf /etc/nginx/nginx.conf

# Expose el puerto 80(HTTP) y 443(HTTPS)
EXPOSE 80
EXPOSE 443

# Inicia el servidor de Nginx en primer plano y lo mantiene en ejecución(tail -f /dev/null)
CMD nginx -g "daemon off;" && tail -f /dev/null